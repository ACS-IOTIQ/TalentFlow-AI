# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://talentflow:talentflow_secure_pass@localhost:5432/talentflow"
POSTGRES_DB="talentflow"
POSTGRES_USER="talentflow"
POSTGRES_PASSWORD="talentflow_secure_pass"

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL="redis://:redis_secure_pass@localhost:6379"
REDIS_PASSWORD="redis_secure_pass"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="change-this-to-a-secure-random-string"
NEXTAUTH_URL="http://localhost:3000"

# ─── MinIO / S3 ───────────────────────────────────────────────────────────────
MINIO_ENDPOINT="http://minio:9000"
MINIO_PUBLIC_ENDPOINT="http://localhost:9000"
MINIO_ROOT_USER="minioadmin"
MINIO_ROOT_PASSWORD="minioadmin123"
MINIO_BUCKET_RESUMES="talentflow-resumes"
MINIO_BUCKET_JDS="talentflow-jds"
MINIO_BUCKET_PROFILES="talentflow-profiles"
MINIO_BUCKET_AVATARS="talentflow-avatars"

# ─── AI (Anthropic Claude or Google Gemini) ───────────────────────────────────
# AI_PROVIDER can be "anthropic" or "gemini". If omitted, Gemini is used when GEMINI_API_KEY is present; otherwise Anthropic is used.
AI_PROVIDER="anthropic"
AI_MODEL=""
ANTHROPIC_API_KEY="your-anthropic-api-key"
ANTHROPIC_MODEL="claude-sonnet-4-6"
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_MODEL="gemini-2.5-flash"
# Optional Gemini-compatible endpoint override
GEMINI_API_BASE="https://generativelanguage.googleapis.com/v1beta"

# ─── Microsoft Teams SSO (optional) ─────────────────────────────────────────
# Create an App Registration in Azure AD to enable MS Teams login
# MS_TENANT_ID="your-tenant-id"
# MS_CLIENT_ID="your-client-id"
# MS_CLIENT_SECRET="your-client-secret"

# ─── Email (optional) ─────────────────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="noreply@acstechnologies.com"
SMTP_PASS=""
SMTP_TLS_REJECT_UNAUTHORIZED="true"
FROM_NAME="Talent Flow AI"
FROM_EMAIL="noreply@acstechnologies.com"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="production"
